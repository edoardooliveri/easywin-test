# Database
DATABASE_URL=postgresql://easywin:password@localhost:5432/easywin
DB_HOST=localhost
DB_PORT=5432
DB_NAME=easywin
DB_USER=easywin
DB_PASSWORD=your_password_here

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret_here_change_in_production

# Claude AI (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Modelli AI — Haiku per import massivo (economico), Sonnet per analisi interattiva (qualità)
AI_MODEL_BULK=claude-haiku-4-5-20251001
AI_MODEL_INTERACTIVE=claude-sonnet-4-20250514

# Presidia Web Service
PRESIDIA_BASE_URL=https://ws.presidia.it/api
PRESIDIA_USERNAME=your_presidia_username
PRESIDIA_PASSWORD=your_presidia_password

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ============ MAIL SYSTEM (PR-MAIL-2a) ============
# Provider scelto: Brevo. Vedi DESIGN_MAIL_SYSTEM.md §1.
MAIL_PROVIDER=brevo
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=                      # email account Brevo
BREVO_SMTP_KEY=                       # API key SMTP generata in Brevo
MAIL_FROM="EasyWin <noreply@easywin.it>"
MAIL_RATE_LIMIT=20                    # messaggi/secondo
MAIL_POOL_SIZE=10                     # connessioni SMTP concorrenti
MAIL_RETRY_ATTEMPTS=2                 # tentativi extra su errori temporanei
MAIL_DRY_RUN=false                    # true = scrive mail_log senza inviare (test)
