# Database
DATABASE_URL=postgresql://easywin:password@localhost:5432/easywin
DB_HOST=localhost
DB_PORT=5432
DB_NAME=easywin
DB_USER=easywin
DB_PASSWORD=your_password_here

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret_here_change_in_production

# Claude AI (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Modelli AI — Haiku per import massivo (economico), Sonnet per analisi interattiva (qualità)
AI_MODEL_BULK=claude-haiku-4-5-20251001
AI_MODEL_INTERACTIVE=claude-sonnet-4-20250514

# Presidia Web Service
PRESIDIA_BASE_URL=https://ws.presidia.it/api
PRESIDIA_USERNAME=your_presidia_username
PRESIDIA_PASSWORD=your_presidia_password

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ── Mail Provider ──────────────────────────────────────────────
# Toggle: 'smtp' (default) | 'ses'
MAIL_PROVIDER=smtp

# SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="EasyWin" <noreply@easywin.it>

# Amazon SES v2 (used when MAIL_PROVIDER=ses)
SES_REGION=eu-south-1
SES_ACCESS_KEY_ID=AKIA...                  # IAM user easywin-ses-sender
SES_SECRET_ACCESS_KEY=...
SES_FROM_ADDRESS=noreply@aura-proptech.com
SES_CONFIGURATION_SET=easywin-ses-tls      # opzionale
